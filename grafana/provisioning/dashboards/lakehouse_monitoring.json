{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "4.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "DataLakehouse ETL pipeline monitoring – pipeline run status, row counts, and data freshness across Bronze/Silver/Gold layers.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Pipeline Run Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Pipeline Runs",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT count() AS total_runs FROM analytics.pipeline_runs",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "success": { "color": "green", "index": 0, "text": "SUCCESS" }, "failed": { "color": "red", "index": 1, "text": "FAILED" }, "running": { "color": "blue", "index": 2, "text": "RUNNING" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "string"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Last Run Status",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT status FROM analytics.pipeline_runs ORDER BY started_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7200 },
              { "color": "red", "value": 25200 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "title": "Time Since Last Success",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT toUnixTimestamp(now()) - toUnixTimestamp(max(started_at)) AS seconds_since_last_success FROM analytics.pipeline_runs WHERE status = 'success'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Last Run – Rows Extracted",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT rows_extracted FROM analytics.pipeline_runs ORDER BY started_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Last Run – Rows Silver",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT rows_silver FROM analytics.pipeline_runs ORDER BY started_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Last Run – Gold Daily Rows",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT rows_gold_daily FROM analytics.pipeline_runs ORDER BY started_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 8,
      "title": "Run History",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "rows_extracted" }, "properties": [{ "id": "displayName", "value": "Rows Extracted (Bronze)" }] },
          { "matcher": { "id": "byName", "options": "rows_silver" }, "properties": [{ "id": "displayName", "value": "Rows Silver" }] },
          { "matcher": { "id": "byName", "options": "rows_gold_daily" }, "properties": [{ "id": "displayName", "value": "Gold Daily Rows" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Row Counts per Pipeline Run",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT started_at AS time, rows_extracted, rows_silver, rows_gold_daily FROM analytics.pipeline_runs WHERE $__timeFilter(started_at) ORDER BY started_at",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 10,
      "options": { "pieType": "pie", "legend": { "displayMode": "list", "placement": "right" } },
      "title": "Run Status Distribution",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT status, count() AS cnt FROM analytics.pipeline_runs WHERE $__timeFilter(started_at) GROUP BY status",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 11,
      "title": "Recent Pipeline Runs",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "status" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{ "options": { "success": { "color": "green", "index": 0 }, "failed": { "color": "red", "index": 1 } }, "type": "value" }] }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "id": 12,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "started_at" }] },
      "title": "Recent Pipeline Runs (last 50)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT run_id, pipeline_name, status, started_at, ended_at, dateDiff('second', started_at, coalesce(ended_at, now())) AS duration_sec, rows_extracted, rows_silver, rows_gold_daily, rows_gold_region, rows_gold_category, error_message FROM analytics.pipeline_runs ORDER BY started_at DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["datalakehouse", "etl", "monitoring"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "DataLakehouse – ETL Pipeline Monitoring",
  "uid": "dlh-etl-monitoring",
  "version": 1
}
