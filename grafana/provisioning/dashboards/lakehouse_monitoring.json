{
  "annotations": { "list": [] },
  "description": "360-degree monitoring for DataLakehouse: Infra, Storage, Pipelines, and DB Performance.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🌐 Global Infrastructure Health",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "justifyMode": "center", "textMode": "value_and_name" },
      "title": "Total Pipelines Active",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" }, "rawSql": "SELECT count(DISTINCT pipeline_name) FROM analytics.pipeline_runs", "format": "table", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "decbytes" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "justifyMode": "center", "textMode": "value_and_name" },
      "title": "Total Lakehouse Size",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" }, "rawSql": "SELECT sum(bytes_on_disk) FROM system.parts WHERE active", "format": "table", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "red", "value": 80 }] }, "unit": "percent" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "justifyMode": "center", "textMode": "value_and_name" },
      "title": "ClickHouse Memory Load",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" }, "rawSql": "SELECT (value / getOSMemoryTotal()) * 100 FROM system.asynchronous_metrics WHERE metric = 'MemoryTotalUsed'", "format": "table", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "justifyMode": "center", "textMode": "value_and_name" },
      "title": "Active DB Connections",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" }, "rawSql": "SELECT value FROM system.metrics WHERE metric = 'TCPConnection' OR metric = 'HTTPConnection' LIMIT 1", "format": "table", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "📐 Medallion Data Flow (Bronze → Silver → Gold)",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 20 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "End-to-End Ingestion Velocity",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" }, "rawSql": "SELECT started_at AS time, rows_extracted AS \"Bronze (Extracted)\", rows_silver AS \"Silver (Cleaned)\" FROM analytics.pipeline_runs WHERE $__timeFilter(started_at) ORDER BY started_at", "format": "time_series", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 8,
      "title": "🪣 Storage Layer (RustFS S3)",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 9,
      "options": { "displayLabels": ["percent"], "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut" },
      "title": "Object Distribution by Layer",
      "type": "piechart",
      "targets": [
        { "datasource": { "type": "postgres", "uid": "postgres_main" }, "format": "table", "rawSql": "SELECT storage_layer, count(*) FROM lakehouse.data_object GROUP BY storage_layer", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 10,
      "options": { "displayLabels": ["percent"], "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut" },
      "title": "Format Distribution",
      "type": "piechart",
      "targets": [
        { "datasource": { "type": "postgres", "uid": "postgres_main" }, "format": "table", "rawSql": "SELECT object_format, count(*) FROM lakehouse.data_object GROUP BY object_format", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 11,
      "title": "⚡ Database Engine Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "continuous-GrYlRd" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Query Latency (P99)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" }, "rawSql": "SELECT event_time AS time, query_duration_ms / 1000.0 AS duration FROM system.query_log WHERE type = 'QueryFinish' AND $__timeFilter(event_time) ORDER BY event_time", "format": "time_series", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decbytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "ClickHouse Memory Consumption Over Time",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" }, "rawSql": "SELECT event_time AS time, value FROM system.metric_log WHERE metric = 'MemoryTracking' AND $__timeFilter(event_time) ORDER BY event_time", "format": "time_series", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 14,
      "title": "📋 Audit & Pipeline History",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "status" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{ "options": { "success": { "color": "green", "text": "SUCCESS" }, "failed": { "color": "red", "text": "FAILED" } }, "type": "value" }] }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "id": 15,
      "options": { "showHeader": true },
      "title": "Recent System-Wide Pipeline Runs",
      "type": "table",
      "targets": [
        { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" }, "rawSql": "SELECT run_id, pipeline_name, status, started_at, rows_extracted, rows_silver, error_message FROM analytics.pipeline_runs ORDER BY started_at DESC LIMIT 50", "format": "table", "refId": "A" }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["datalakehouse", "full-stack", "infra", "storage"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "DataLakehouse 360° Command Center",
  "uid": "dlh-360-command-center",
  "version": 1,
  "weekStart": ""
}
