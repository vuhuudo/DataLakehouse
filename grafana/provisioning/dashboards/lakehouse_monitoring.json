{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "4.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Comprehensive command center for DataLakehouse: ETL health, Storage stats, and DB performance.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "System Pulse",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6BC46D", "value": null },
              { "color": "#F2C96D", "value": 1 },
              { "color": "#E24D42", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Total ETL Runs",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT count() AS total_runs FROM analytics.pipeline_runs",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "success": { "text": "SUCCESS", "color": "green", "index": 0 },
                "failed": { "text": "FAILED", "color": "red", "index": 1 },
                "running": { "text": "RUNNING", "color": "blue", "index": 2 },
                "no_data": { "text": "NO DATA", "color": "gray", "index": 3 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "string"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Last Run Status",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT coalesce(status, 'no_data') FROM (SELECT 1) LEFT JOIN (SELECT status FROM analytics.pipeline_runs ORDER BY started_at DESC LIMIT 1) ON 1=1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6BC46D", "value": null },
              { "color": "#F2C96D", "value": 10000 },
              { "color": "#E24D42", "value": 50000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Last CSV Raw Rows",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT coalesce(raw_rows, 0) FROM (SELECT 1) LEFT JOIN (SELECT raw_rows FROM analytics.csv_quality_metrics ORDER BY processed_at DESC LIMIT 1) ON 1=1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#E24D42", "value": null },
              { "color": "#F2C96D", "value": 90 },
              { "color": "#6BC46D", "value": 98 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Last CSV Quality Score",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT coalesce(if(raw_rows = 0, 0, 100.0 * cleaned_rows / raw_rows), 0) FROM (SELECT 1) LEFT JOIN (SELECT raw_rows, cleaned_rows FROM analytics.csv_quality_metrics ORDER BY processed_at DESC LIMIT 1) ON 1=1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#6BC46D", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "CSV Files Processed",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT countIf(status = 'success') AS files_processed FROM analytics.csv_upload_events",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6BC46D", "value": null },
              { "color": "#E24D42", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "CSV Failed Files",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT countIf(status = 'failed') AS failed_files FROM analytics.csv_upload_events",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 15,
      "title": "Storage & Database Health",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
      "id": 16,
      "options": {
        "colorMode": "value",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Datasets (Metadata)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres_main" },
          "format": "table",
          "rawSql": "SELECT count(*) FROM lakehouse.dataset",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
      "id": 17,
      "options": {
        "colorMode": "value",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Data Objects (Lake)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres_main" },
          "format": "table",
          "rawSql": "SELECT count(*) FROM lakehouse.data_object",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "unit": "decbytes"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "id": 18,
      "options": {
        "colorMode": "value",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "ClickHouse Disk Usage",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "format": "table",
          "rawSql": "SELECT sum(bytes_on_disk) FROM system.parts WHERE active",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "id": 19,
      "options": {
        "colorMode": "value",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Active Parts Count",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "format": "table",
          "rawSql": "SELECT count() FROM system.parts WHERE active",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 8,
      "title": "Ingestion Trends",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "raw_rows" }, "properties": [{ "id": "displayName", "value": "CSV Raw Rows" }] },
          { "matcher": { "id": "byName", "options": "cleaned_rows" }, "properties": [{ "id": "displayName", "value": "CSV Cleaned Rows" }] },
          { "matcher": { "id": "byName", "options": "dropped_rows" }, "properties": [{ "id": "displayName", "value": "Dropped Rows" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 11 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "CSV Quality Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT processed_at AS time, raw_rows, cleaned_rows, dropped_rows FROM analytics.csv_quality_metrics WHERE $__timeFilter(processed_at) ORDER BY processed_at",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 11 },
      "id": 10,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut"
      },
      "title": "CSV Upload Status Mix",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT status, count() AS cnt FROM analytics.csv_upload_events WHERE $__timeFilter(processed_at) GROUP BY status",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "rows_extracted" }, "properties": [{ "id": "displayName", "value": "Rows Extracted" }] },
          { "matcher": { "id": "byName", "options": "rows_silver" }, "properties": [{ "id": "displayName", "value": "Rows Silver" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Pipeline Throughput (All Pipelines)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT started_at AS time, rows_extracted, rows_silver FROM analytics.pipeline_runs WHERE $__timeFilter(started_at) ORDER BY started_at",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 12,
      "title": "Operational Details",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "success": { "color": "green", "index": 0, "text": "SUCCESS" },
                      "failed": { "color": "red", "index": 1, "text": "FAILED" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 28 },
      "id": 13,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "processed_at" }]
      },
      "title": "Recent CSV Upload Events",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT source_key, status, row_count, duplicate_rows, dropped_rows, processed_at, pipeline_run_id, error_message FROM analytics.csv_upload_events ORDER BY processed_at DESC LIMIT 30",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 28 },
      "id": 14,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "started_at" }]
      },
      "title": "Recent Pipeline Runs",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_main" },
          "rawSql": "SELECT run_id, pipeline_name, status, started_at, ended_at, dateDiff('second', started_at, coalesce(ended_at, now())) AS duration_sec, rows_extracted, rows_silver, error_message FROM analytics.pipeline_runs ORDER BY started_at DESC LIMIT 30",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["datalakehouse", "monitoring", "etl", "infra"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "DataLakehouse Command Center",
  "uid": "dlh-etl-monitoring",
  "version": 3,
  "weekStart": ""
}
