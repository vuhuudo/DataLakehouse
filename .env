# ============================================================
# DataLakehouse – environment configuration
# ============================================================
# IMPORTANT: This file contains default development credentials only.
# Never use these values in production.
# ============================================================

# ------------------------------------------------------------
# PostgreSQL 17
# ------------------------------------------------------------
POSTGRES_DB=datalakehouse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=55432

# ------------------------------------------------------------
# RustFS (S3-compatible object storage)
# Docs: https://rustfs.com
# Default console: http://localhost:19001
# ------------------------------------------------------------
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_API_PORT=19000
RUSTFS_CONSOLE_PORT=19001
