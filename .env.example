# ============================================================
# DataLakehouse – environment configuration example
# ============================================================
# Copy this file to .env and update values for your environment.
# Run  scripts/setup.sh  for an interactive guided setup.
# ============================================================

# Global timezone for all services
TZ=Asia/Ho_Chi_Minh

# Bind published ports to a specific host IP.
# Use 127.0.0.1 for local-only access, or set your LAN IP like 192.168.1.10 for LAN access only.
DLH_BIND_IP=127.0.0.1

# PostgreSQL hostname for services that read POSTGRES_HOST.
# For an external/remote Postgres, update this value and also review any
# repo files that may still reference `dlh-postgres` directly (for example
# mage/io_config.yaml and io_config.yaml).
POSTGRES_HOST=dlh-postgres

# ============================================================
# Docker Image Versions
# Pin specific tags here instead of editing docker-compose.yaml.
# ============================================================
POSTGRES_IMAGE_VERSION=17-alpine
RUSTFS_IMAGE_VERSION=latest
MINIO_MC_IMAGE_VERSION=latest
CLICKHOUSE_IMAGE_VERSION=latest
MAGE_IMAGE_VERSION=latest
NOCODB_IMAGE_VERSION=latest
SUPERSET_IMAGE_VERSION=latest
GRAFANA_IMAGE_VERSION=latest

# ============================================================
# Core PostgreSQL (shared metadata/config DB for stack services)
# ============================================================
POSTGRES_DB=datalakehouse
POSTGRES_USER=dlh_admin
POSTGRES_PASSWORD=change-this-admin-password
DLH_POSTGRES_PORT=25432

# ============================================================
# Custom PostgreSQL workspace (optional)
# Fill these in to create an isolated DB / schema / user that
# does NOT conflict with the system databases (mage, superset …).
# Leave CUSTOM_DB_NAME blank to skip custom DB creation.
# ETL and dashboards will prefer these variables when set.
# ============================================================
CUSTOM_DB_NAME=dlh_custom
CUSTOM_DB_USER=dlh_custom_user
CUSTOM_DB_PASSWORD=change-this-custom-password
CUSTOM_SCHEMA=custom_schema

# ============================================================
# RustFS (S3-compatible object storage)
# ============================================================
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
DLH_RUSTFS_API_PORT=29100
DLH_RUSTFS_CONSOLE_PORT=29101
RUSTFS_CORS_ALLOWED_ORIGINS=http://localhost:29100
RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=http://localhost:29101
RUSTFS_BUCKET=nocodb
# ETL bucket names (created automatically by rustfs-init)
RUSTFS_BRONZE_BUCKET=bronze
RUSTFS_SILVER_BUCKET=silver
RUSTFS_GOLD_BUCKET=gold
# RustFS internal bind addresses (rarely need changing)
RUSTFS_VOLUMES=/data
RUSTFS_ADDRESS=0.0.0.0:9000
RUSTFS_CONSOLE_ADDRESS=0.0.0.0:9001
# RustFS S3 endpoint reachable from other containers
RUSTFS_ENDPOINT_URL=http://dlh-rustfs:9000
# Litestream backup endpoint (NocoDB)
LITESTREAM_S3_ENDPOINT=http://dlh-rustfs:9000

# ============================================================
# ClickHouse (OLAP serving layer)
# ============================================================
CLICKHOUSE_HOST=dlh-clickhouse
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
DLH_CLICKHOUSE_HTTP_PORT=28123
DLH_CLICKHOUSE_TCP_PORT=29000

# ============================================================
# Mage (ETL / pipeline engine)
# ============================================================
DLH_MAGE_PORT=26789
MAGE_DB_NAME=dlh_mage
MAGE_DB_USER=dlh_mage_user
MAGE_DB_PASSWORD=change-this-mage-password
# Mage internal code paths (container-internal; change only if mounting a custom path)
MAGE_CODE_PATH=/home/src
USER_CODE_PATH=/home/src
# ETL source – uses CUSTOM_DB_* when set, otherwise falls back here
SOURCE_DB_NAME=datalakehouse
SOURCE_DB_USER=dlh_admin
SOURCE_DB_PASSWORD=change-this-admin-password
SOURCE_SCHEMA=public
SOURCE_TABLE=
SOURCE_TABLE_CANDIDATES=Demo,test_projects
CSV_UPLOAD_BUCKET=bronze
CSV_UPLOAD_PREFIX=csv_upload/
CSV_UPLOAD_ALLOW_ANYWHERE=true
CSV_UPLOAD_SEPARATOR=,
CSV_UPLOAD_ENCODING=utf-8
CSV_UPLOAD_SCAN_LIMIT=200

# ============================================================
# NocoDB
# ============================================================
DLH_NOCODB_PORT=28082
NOCODB_DB_NAME=dlh_nocodb
NOCODB_DB_USER=dlh_nocodb_user
NOCODB_DB_PASSWORD=change-this-nocodb-password
# Public-facing URL for NocoDB (used for redirects and SSO callbacks)
NOCODB_PUBLIC_URL=http://127.0.0.1:28082
NOCODB_BACKEND_URL=http://127.0.0.1:28082

# ============================================================
# Superset
# ============================================================
DLH_SUPERSET_PORT=28088
SUPERSET_SECRET_KEY=replace-this-secret
SUPERSET_DB_NAME=dlh_superset
SUPERSET_DB_USER=dlh_superset_user
SUPERSET_DB_PASSWORD=change-this-superset-db-password
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@superset.local
# Superset internal config path (container-internal; matches volume mount in compose)
SUPERSET_CONFIG_PATH=/app/pythonpath/superset_config.py
SUPERSET_LOAD_EXAMPLES=no

# ============================================================
# Grafana
# ============================================================
DLH_GRAFANA_PORT=23001
GRAFANA_DB_NAME=dlh_grafana
GRAFANA_DB_USER=dlh_grafana_user
GRAFANA_DB_PASSWORD=change-this-grafana-db-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Grafana database host (format: host:port). Update if you change POSTGRES_HOST.
GF_DATABASE_HOST=dlh-postgres:5432
# Comma-separated list of Grafana plugins to install on startup
GF_INSTALL_PLUGINS=grafana-piechart-panel,grafana-clickhouse-datasource

# ============================================================
# Nginx Proxy Manager (optional)
# ============================================================
DLH_NPM_HTTP_PORT=28080
DLH_NPM_HTTPS_PORT=28443
DLH_NPM_ADMIN_PORT=28081
