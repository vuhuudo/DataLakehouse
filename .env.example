# ============================================================
# DataLakehouse – environment configuration example
# ============================================================
# Copy this file to .env and update values for your environment.
# ============================================================

# Global timezone for all services
TZ=Asia/Ho_Chi_Minh

# Bind published ports to a specific host IP.
# Use 127.0.0.1 for local-only access, or set your LAN IP like 192.168.1.10 for LAN access only.
DLH_BIND_IP=127.0.0.1

# Core PostgreSQL (shared metadata/config DB)
POSTGRES_DB=datalakehouse
POSTGRES_USER=dlh_admin
POSTGRES_PASSWORD=change-this-admin-password
DLH_POSTGRES_PORT=25432

# RustFS
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
DLH_RUSTFS_API_PORT=29100
DLH_RUSTFS_CONSOLE_PORT=29101
RUSTFS_CORS_ALLOWED_ORIGINS=http://localhost:29100
RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=http://localhost:29101
RUSTFS_BUCKET=nocodb
# ETL bucket names (created automatically by rustfs-init)
RUSTFS_BRONZE_BUCKET=bronze
RUSTFS_SILVER_BUCKET=silver
RUSTFS_GOLD_BUCKET=gold

# ClickHouse
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
DLH_CLICKHOUSE_HTTP_PORT=28123
DLH_CLICKHOUSE_TCP_PORT=29000

# Mage
DLH_MAGE_PORT=26789
MAGE_DB_NAME=dlh_mage
MAGE_DB_USER=dlh_mage_user
MAGE_DB_PASSWORD=change-this-mage-password

# NocoDB
DLH_NOCODB_PORT=28082
NOCODB_DB_NAME=dlh_nocodb
NOCODB_DB_USER=dlh_nocodb_user
NOCODB_DB_PASSWORD=change-this-nocodb-password

# Superset
DLH_SUPERSET_PORT=28088
SUPERSET_SECRET_KEY=replace-this-secret
SUPERSET_DB_NAME=dlh_superset
SUPERSET_DB_USER=dlh_superset_user
SUPERSET_DB_PASSWORD=change-this-superset-db-password
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@superset.local

# Grafana
DLH_GRAFANA_PORT=23001
GRAFANA_DB_NAME=dlh_grafana
GRAFANA_DB_USER=dlh_grafana_user
GRAFANA_DB_PASSWORD=change-this-grafana-db-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Nginx Proxy Manager
DLH_NPM_HTTP_PORT=28080
DLH_NPM_HTTPS_PORT=28443
DLH_NPM_ADMIN_PORT=28081
